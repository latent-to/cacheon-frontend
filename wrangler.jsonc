{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cacheon-frontend",
  "compatibility_date": "2026-04-20",
  "main": "./workers/app.ts",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "OPENROUTER_MODEL": "qwen/qwen3.6-flash"
  },
  "ratelimits": [
    {
      "name": "CHAT_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": {
        "limit": 30,
        "period": 60
      }
    }
  ]
}
