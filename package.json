{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "prebuild": "fumadocs-mdx && react-router typegen && wrangler types",
    "build": "react-router build",
    "typecheck": "fumadocs-mdx && react-router typegen && wrangler types && tsc -b",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "postinstall": "fumadocs-mdx && react-router typegen && wrangler types"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-router/node": "^7.14.0",
    "@types/mdx": "^2.0.13",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.8.1",
    "fumadocs-mdx": "^14.3.1",
    "fumadocs-ui": "^16.8.1",
    "isbot": "^5.1.17",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.16.0",
    "ogl": "^1.0.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.15.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.3",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@eslint/js": "^9.39.4",
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "wrangler": "^4.83.0"
  },
  "overrides": {
    "vite-node": {
      "vite": "$vite"
    }
  }
}
